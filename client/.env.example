# Frontend environment — copy to client/.env

# Dev: Vite proxy handles /api automatically
VITE_API_URL=/api

# Production (Render static site): REQUIRED — must end with /api
# VITE_API_URL=https://your-backend.onrender.com/api

# Optional: Socket.io (auto-derived from VITE_API_URL if omitted)
# VITE_SOCKET_URL=https://your-backend.onrender.com