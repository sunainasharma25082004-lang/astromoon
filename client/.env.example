# Frontend environment — copy to client/.env

# Dev: Vite proxy handles /api automatically
VITE_API_URL=/api

# Production (separate deploy): point to live backend
# VITE_API_URL=https://your-api.onrender.com/api

# Production Socket.io (same origin if combined deploy, else backend URL)
# VITE_SOCKET_URL=https://your-api.onrender.com