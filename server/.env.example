# Celestial Guidance - Backend Environment
# Copy to server/.env and fill real values

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/celestial-guidance?retryWrites=true&w=majority

# Strong random secret (required)
JWT_SECRET=your_long_random_jwt_secret_here

# Frontend URL for CORS (production: your deployed frontend URL, no trailing slash)
FRONTEND_URL=http://localhost:5173
# Optional: multiple origins (comma-separated)
# FRONTEND_URLS=https://your-frontend.onrender.com,https://www.yourdomain.com

# Set on Render backend
# NODE_ENV=production

# Optional: Razorpay (admin will add later)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=